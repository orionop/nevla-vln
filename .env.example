# VLN Challenge — environment variables (TEMPLATE).
# Copy to `.env` (gitignored) and fill in real values:
#     cp .env.example .env
# The orchestrator auto-loads `.env` at runtime (see reasoning/vlm_client.py),
# so you do NOT need to `source` it. NEVER commit `.env` with real keys.

# --- VLM provider keys (set the one you use) ---
# Google Gemini (OpenAI-compatible endpoint). Preferred provider.
GEMINI_API_KEY=
# Alibaba Qwen / DashScope (alternative). Leave blank if unused.
DASHSCOPE_API_KEY=

# --- VLA-3D dataset (dev/scoring only; not needed at runtime) ---
# Path to the unzipped VLA-3D Unity scenes (15 training scenes). Used by the
# eval harness to load GT object boxes/colors. Download:
#   python download_dataset.py --download_path vla3d --subset Unity
# VLA3D_DIR=/abs/path/to/vla3d/Unity

# --- Optional overrides (sensible defaults baked into vlm_client.py) ---
# Force a provider regardless of which key is set: "gemini" or "qwen".
# VLM_PROVIDER=gemini
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_LITE=gemini-2.5-flash-lite
# QWEN_MODEL=qwen3.6-plus
# QWEN_MODEL_LITE=qwen3.6-flash
